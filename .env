# ─────────────────────────────────────────────
# AI Job Agent — Environment Variables
# ─────────────────────────────────────────────

# JOB SEARCH
# Comma-separated queries — covers Django, DRF, FastAPI, and general Python backend
JOB_SEARCH_QUERIES=Python Django Developer,Python Backend Engineer,Django REST Framework Developer,FastAPI Backend Developer,Senior Python Developer

# Job sites to search (supported: linkedin, indeed, zip_recruiter, glassdoor, google)
JOB_SITES=linkedin,indeed,zip_recruiter

# Remote filtering is handled per-site automatically by scraper.py:
#   LinkedIn + ZipRecruiter → is_remote=True flag
#   Indeed                  → "remote" keyword appended to each query + country_indeed="usa"

# Max results fetched PER query PER site group (before dedup + filtering)
JOB_MAX_RESULTS_PER_QUERY=5

# Only fetch jobs posted in last N hours
JOB_HOURS_OLD=24

# RESUME
RESUME_PDF_PATH=SWE-Abdul Rehman Sohail-Python.pdf
OUTPUT_DIR=tailored_resumes


# EMAIL (Gmail) — add later
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# SCHEDULER
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0

