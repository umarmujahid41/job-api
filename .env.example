# ─────────────────────────────────────────────
# AI Job Agent - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# JOB SEARCH
JOB_SEARCH_QUERY=AI Product Manager
JOB_SEARCH_LOCATION=United States
JOB_MAX_RESULTS=5
JOB_HOURS_OLD=24

# RESUME
RESUME_PDF_PATH=resume.pdf
OUTPUT_DIR=tailored_resumes

# OPENAI
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o

# EMAIL (Gmail)
# To get an App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=your.email@gmail.com

# SCHEDULER (24h format)
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
